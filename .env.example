# Copy to .env and fill in. Do not commit .env.
# SECRET_KEY is used to encrypt credentials in the local DB (backend/instance/credentials.db).
SECRET_KEY=your-secret-key-change-in-production

# Optional: path to your inventory CSV (default: backend/inventory/inventory.csv).
# PERGEN_INVENTORY_PATH=/path/to/inventory.csv

# Optional: Flask bind (default: 127.0.0.1). Use 0.0.0.0 for production.
# FLASK_RUN_HOST=0.0.0.0
