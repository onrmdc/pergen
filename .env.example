# Copy to .env and fill in. Do not commit .env.
#
# Loading: ./run.sh auto-loads this file at startup (line-by-line; existing
# shell env vars take precedence). Flask CLI also auto-loads it when
# python-dotenv is installed (see requirements.txt).

# SECRET_KEY is used to encrypt credentials in the local DB.
# In production this is a hard requirement; ProductionConfig refuses
# to boot with the placeholder value.
SECRET_KEY=your-secret-key-change-in-production

# --- API authentication (audit H-05 / wave-7) ----------------------------
#
# Pick ONE auth posture below. Setting BOTH a token AND PERGEN_DEV_OPEN_API
# is a contradictory configuration: the runtime gate ALWAYS enforces tokens
# when any are configured, so PERGEN_DEV_OPEN_API has no effect. The boot
# emits a WARN (wave-7.2) but does not refuse — operator chooses one.
#
# === Posture A: token auth (recommended; SPA + CLI both work) ============
# Each token must be at least 32 characters. Generate with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(32))"
#
# Single-actor (everyone uses the same token; flask.g.actor = "shared"):
# PERGEN_API_TOKEN=replace-me-with-32+-random-chars-min
#
# Per-actor (preferred for audit-log accountability):
# PERGEN_API_TOKENS=alice:tok-32-chars-or-more,bob:tok-32-chars-or-more
#
# IMPORTANT: for the SPA to work in token mode you MUST also set the next
# line — otherwise the browser cannot send the token (it has no way to
# stash an X-API-Token header in a fetch call). When this is set, /login
# becomes a real login page; the operator types their actor name as the
# username and the token as the password.
# PERGEN_AUTH_COOKIE_ENABLED=1
#
# === Posture B: open API (dev/internal-only, no auth) ====================
# Explicitly opt in to the open-API posture instead of configuring tokens.
# The factory refuses to boot in development without either tokens OR this
# flag. /api/* will accept any caller with no auth check.
# PERGEN_DEV_OPEN_API=1

# --- Optional knobs ------------------------------------------------------
# Path to your inventory CSV (default: backend/inventory/inventory.csv).
# PERGEN_INVENTORY_PATH=/path/to/inventory.csv

# Flask bind (default: 127.0.0.1). Use 0.0.0.0 for production.
# FLASK_RUN_HOST=0.0.0.0

# Wave-7 session lifetime (cookie auth path; default 8 hours).
# PERGEN_SESSION_LIFETIME_HOURS=8
# PERGEN_SESSION_IDLE_HOURS=8

# Wave-7 reverse-proxy trust (mount ProxyFix). Set ONLY when behind a
# trusted nginx / Caddy / cloud LB.
# PERGEN_TRUST_PROXY=1

# Wave-7.1 SSRF guard on /api/ping. Default-allow internal targets;
# set =1 to re-enable the audit-H3 default-deny for internet-exposed
# deployments.
# PERGEN_BLOCK_INTERNAL_PING=1

# Wave-7.1 SSH host-key policy. AutoAddPolicy is the intentional
# default for internal device enrollment; set =1 (with KNOWN_HOSTS
# pointing to a populated file) to lock down to RejectPolicy.
# PERGEN_SSH_STRICT_HOST_KEY=1
# PERGEN_SSH_KNOWN_HOSTS=/path/to/known_hosts
